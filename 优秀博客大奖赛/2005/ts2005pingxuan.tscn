[node name="01" type="RichTextLabel" parent="." unique_id=1037505400]
offset_left = 20.0
offset_top = 430.0
offset_right = 500.0
offset_bottom = 455.0
text = "评选开始了。"
visible_characters = 0
visible_ratio = 0.0

[node name="02" type="RichTextLabel" parent="." unique_id=1803567681]
offset_left = 20.0
offset_top = 430.0
offset_right = 500.0
offset_bottom = 455.0
text = "评审团收到了来自中文博客圈数百份提名。"
visible_characters = 0
visible_ratio = 0.0

[node name="03" type="RichTextLabel" parent="." unique_id=1753201945]
offset_left = 20.0
offset_top = 430.0
offset_right = 752.0
offset_bottom = 455.0
text = "这是博客联盟第一次举办这样的评选。三年来，无数博主在网络上坚持记录。"
visible_characters = 0
visible_ratio = 0.0

[node name="04" type="RichTextLabel" parent="." unique_id=262936621]
offset_left = 20.0
offset_top = 430.0
offset_right = 500.0
offset_bottom = 455.0
text = "评审团在 200+ 提名中，将遴选出最终的获奖者。"
visible_characters = 0
visible_ratio = 0.0

[node name="05" type="RichTextLabel" parent="." unique_id=1685236201]
offset_left = 20.0
offset_top = 430.0
offset_right = 500.0
offset_bottom = 455.0
text = "最终结果将于 12 月颁奖典礼上正式公布。"
visible_characters = 0
visible_ratio = 0.0

